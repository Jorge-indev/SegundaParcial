@page "/inventario"
@rendermode InteractiveServer

<h3>Registro de productos</h3>

<div class="card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <label>No. de inventario</label>
                <input type="number" class="form-control" @bind="_numeroInventario" />
            </div>
            <div class="col-md-4">
                <label>Descripción</label>
                <input type="text" class="form-control" @bind="_descripcion" />
            </div>
            <div class="col-md-4">
                <label>Departamento</label>
                <select class="form-select" @bind="_departamento">
                    <option value="Frutas">Frutas</option>
                    <option value="Verduras">Verduras</option>
                    <option value="Lacteos">Lácteos</option>
                </select>
            </div>
        </div>
        <div class="row mt-3">
            <div class="col-md-12">
                
                @if (_mensajeError != "")
                {
                    <span class="text-danger">@_mensajeError</span>
                }
                @if (_mensajeExito != "")
                {
                    <span class="text-success">@_mensajeExito</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-12">
        <button class="btn btn-primary" @onclick="GuardarProducto">Guardar datos</button>
        <button class="btn btn-success" @onclick="MostrarListaCompleta">Lista completa</button>
        <button class="btn btn-success" @onclick="MostrarFrutas">Lista de frutas</button>
        <button class="btn btn-success" @onclick="MostrarVerduras">Lista de verduras</button>
        <button class="btn btn-success" @onclick="MostrarLacteos">Lista de lácteos</button>
        @if (_mostrarLista)
        {
            <button class="btn btn-danger" @onclick="CerrarLista">Cerrar lista</button>
        }
    </div>
</div>

@if (_mostrarLista)
{
    <div class="row mt-4">
        <div class="col-md-10">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>No. Inventario</th>
                        <th>Descripción</th>
                        <th>Departamento</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        // Listas temporales para los índices que cumplen el filtro
                        List<int> indicesMostrar = new List<int>();
                        for (int i = 0; i < _inventarios.Count; i++)
                        {
                            bool cumple = false;
                            if (_filtro == "completa")
                            {
                                cumple = true;
                            }
                            else if (_filtro == "frutas")
                            {
                                if (_departamentos[i] == "Frutas")
                                    cumple = true;
                            }
                            else if (_filtro == "verduras")
                            {
                                if (_departamentos[i] == "Verduras")
                                    cumple = true;
                            }
                            else if (_filtro == "lacteos")
                            {
                                if (_departamentos[i] == "Lacteos")
                                    cumple = true;
                            }

                            if (cumple)
                            {
                                indicesMostrar.Add(i);
                            }
                        }
                    }

                    @if (indicesMostrar.Count == 0)
                    {
                        <tr>
                            <td colspan="3">No hay productos para mostrar</td>
                        </tr>
                    }
                    else
                    {
                        foreach (int idx in indicesMostrar)
                        {
                            <tr>
                                <td>@_inventarios[idx]</td>
                                <td>@_descripciones[idx]</td>
                                <td>@_departamentos[idx]</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<int> _inventarios = new List<int>();
    private List<string> _descripciones = new List<string>();
    private List<string> _departamentos = new List<string>();

    private int _numeroInventario;
    private string _descripcion = "";
    private string _departamento = "Frutas";

    private string _mensajeError = "";
    private string _mensajeExito = "";

    private bool _mostrarLista = false;
    private string _filtro = "completa";

    private void GuardarProducto()
    {
        _mensajeError = "";
        _mensajeExito = "";

        if (_descripcion == "")
        {
            _mensajeError = "La descripción no puede estar vacía.";
            return;
        }

        if (_numeroInventario <= 0)
        {
            _mensajeError = "El número de inventario debe ser mayor que cero.";
            return;
        }

        bool repetido = false;
        foreach (int inv in _inventarios)
        {
            if (inv == _numeroInventario)
            {
                repetido = true;
                break;
            }
        }
        if (repetido)
        {
            _mensajeError = "El número de inventario " + _numeroInventario + " ya existe.";
            return;
        }

        
        int indice = 0;
        while (indice < _inventarios.Count && _inventarios[indice] < _numeroInventario)
        {
            indice++;
        }

        _inventarios.Insert(indice, _numeroInventario);
        _descripciones.Insert(indice, _descripcion);
        _departamentos.Insert(indice, _departamento);

        _numeroInventario = 0;
        _descripcion = "";
        _departamento = "Frutas";

        _mensajeExito = "Producto guardado correctamente.";
    }

    private void MostrarListaCompleta()
    {
        _filtro = "completa";
        _mostrarLista = true;
    }

    private void MostrarFrutas()
    {
        _filtro = "frutas";
        _mostrarLista = true;
    }

    private void MostrarVerduras()
    {
        _filtro = "verduras";
        _mostrarLista = true;
    }

    private void MostrarLacteos()
    {
        _filtro = "lacteos";
        _mostrarLista = true;
    }

    private void CerrarLista()
    {
        _mostrarLista = false;
    }
}
